---
interface Props {
  title: string;
  description?: string;
}
const { title, description = 'matrix-ao — アニメの配信・グッズ予約・特典比較を公式情報だけでまとめる推し活ナビ' } = Astro.props;
---
<!doctype html>
<html lang="ja">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{title} | matrix-ao</title>
  <meta name="description" content={description} />
  <link rel="sitemap" href="/sitemap-index.xml" />
  <link rel="alternate" type="application/rss+xml" title="matrix-ao RSS" href="/rss.xml" />
  <style>
    :root {
      --max-w: 1080px;
      --c-bg: #faf9fc;
      --c-card: #ffffff;
      --c-fg: #211f33;
      --c-muted: #6b7280;
      --c-border: #e7e4f0;
      --c-accent: #6d28d9;
      --c-accent-dark: #4c1d95;
      --c-accent-soft: #f3eefe;
      --c-warn: #b45309;
      --c-warn-soft: #fef3e2;
      --c-ok: #047857;
      --c-ok-soft: #e8f7f1;
    }
    *, *::before, *::after { box-sizing: border-box; margin: 0; }
    body {
      font-family: -apple-system, BlinkMacSystemFont, 'Hiragino Sans', 'Noto Sans JP', 'Segoe UI', sans-serif;
      background: var(--c-bg); color: var(--c-fg); line-height: 1.75; font-size: 15.5px;
    }
    a { color: var(--c-accent); text-decoration: none; }
    a:hover { text-decoration: underline; }
    h1 { font-size: 1.7rem; line-height: 1.4; }
    h2 { font-size: 1.25rem; margin: 2.2rem 0 0.8rem; padding-left: 0.6rem; border-left: 4px solid var(--c-accent); }
    h3 { font-size: 1.05rem; }

    .trustbar {
      background: var(--c-accent-dark); color: #ede9fe; font-size: 0.78rem;
      text-align: center; padding: 0.35rem 1rem;
    }
    header.site { background: var(--c-card); border-bottom: 1px solid var(--c-border); }
    header.site .inner {
      max-width: var(--max-w); margin: 0 auto; padding: 0.8rem 1rem;
      display: flex; gap: 1.4rem; align-items: baseline; flex-wrap: wrap;
    }
    .logo { font-weight: 800; font-size: 1.25rem; color: var(--c-accent-dark); letter-spacing: 0.02em; }
    .logo:hover { text-decoration: none; }
    .logo small { font-weight: 600; font-size: 0.72rem; color: var(--c-muted); margin-left: 0.5rem; }
    header.site nav { display: flex; gap: 1.1rem; font-size: 0.92rem; font-weight: 600; }

    main { max-width: var(--max-w); margin: 1.8rem auto 0; padding: 0 1rem; }

    footer.site { border-top: 1px solid var(--c-border); background: var(--c-card); margin-top: 4rem; }
    footer.site .inner { max-width: var(--max-w); margin: 0 auto; padding: 1.6rem 1rem; color: var(--c-muted); font-size: 0.8rem; }

    .card {
      background: var(--c-card); border: 1px solid var(--c-border); border-radius: 10px;
      padding: 1.1rem 1.2rem; margin-bottom: 0.9rem;
    }
    a.card { display: block; color: inherit; transition: border-color 0.15s, box-shadow 0.15s; }
    a.card:hover { text-decoration: none; border-color: var(--c-accent); box-shadow: 0 2px 10px rgba(109, 40, 217, 0.08); }
    .meta { color: var(--c-muted); font-size: 0.83rem; }

    .badge {
      display: inline-block; font-size: 0.72rem; font-weight: 700; line-height: 1.5;
      padding: 0.05rem 0.55rem; border-radius: 99px; vertical-align: middle;
    }
    .badge.official { background: var(--c-accent-soft); color: var(--c-accent-dark); }
    .badge.pr { background: var(--c-warn-soft); color: var(--c-warn); }
    .badge.ok { background: var(--c-ok-soft); color: var(--c-ok); }
    .badge.deadline { background: #fde8e8; color: #b91c1c; }
    .badge.sample { background: #eceef2; color: #4b5563; }

    table.cmp { width: 100%; border-collapse: collapse; background: var(--c-card); border-radius: 10px; overflow: hidden; font-size: 0.9rem; }
    table.cmp th, table.cmp td { border: 1px solid var(--c-border); padding: 0.55rem 0.7rem; text-align: left; }
    table.cmp thead th { background: var(--c-accent-soft); color: var(--c-accent-dark); font-size: 0.82rem; }
    table.cmp td.center, table.cmp th.center { text-align: center; }
    table.cmp .avail { color: var(--c-ok); font-weight: 700; }
    table.cmp .none { color: #c0c4cc; }
    .table-scroll { overflow-x: auto; }

    .cta {
      display: inline-block; background: var(--c-accent); color: #fff; font-weight: 700;
      padding: 0.55rem 1.3rem; border-radius: 8px; font-size: 0.92rem;
    }
    .cta:hover { background: var(--c-accent-dark); text-decoration: none; }
    .cta.sub { background: var(--c-card); color: var(--c-accent); border: 1.5px solid var(--c-accent); }
    .cta.sub:hover { background: var(--c-accent-soft); }

    .notice {
      background: var(--c-warn-soft); border: 1px solid #f5d9ae; border-radius: 8px;
      padding: 0.6rem 0.9rem; font-size: 0.83rem; color: var(--c-warn); margin: 1rem 0;
    }
    .disclaimer {
      background: var(--c-card); border: 1px solid var(--c-border); border-radius: 8px;
      padding: 0.8rem 1rem; margin-top: 2rem; font-size: 0.8rem; color: var(--c-muted);
    }
    @media (max-width: 720px) {
      h1 { font-size: 1.35rem; }
      header.site nav { gap: 0.8rem; font-size: 0.85rem; }
    }
  </style>
</head>
<body>
  <div class="trustbar">公式ソースのみ要約 / 本文・画像の転載なし / 広告リンクにはPR表記あり / 全ページに確認日を掲載</div>
  <header class="site">
    <div class="inner">
      <a href="/" class="logo">matrix-ao<small>アニメ配信・予約・特典ナビ</small></a>
      <nav>
        <a href="/streaming/">配信どこで見れる</a>
        <a href="/goods/">グッズ予約・特典</a>
        <a href="/news/">ニュース</a>
      </nav>
    </div>
  </header>
  <main>
    <slot />
  </main>
  <footer class="site">
    <div class="inner">
      <p>&copy; 2026 matrix-ao. 当サイトの情報は各公式サイトの発表に基づく要約です。配信状況・価格・特典は変更される場合があるため、必ずリンク先の公式情報をご確認ください。</p>
      <p>当サイトはアフィリエイトプログラムに参加しており、リンク経由の申込・購入により報酬を受け取る場合があります。該当リンクにはPR表記をしています。</p>
    </div>
  </footer>
</body>
</html>
