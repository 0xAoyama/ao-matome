---
import Base from '../../layouts/Base.astro';
import { getPosts } from '../../lib/posts';
const posts = getPosts('life');
---
<Base title="Life — 生活防衛" description="値上げ、セール、ポイント、ふるさと納税、税制変更の情報まとめ">
  <h1>Life — 生活防衛</h1>
  <p>値上げ、セール、ポイント、ふるさと納税、税制変更の公式情報まとめ</p>
  {posts.map(p => (
    <a href={`/life/${p.slug}/`} class="card" style="display:block; margin-top:1rem;">
      <h3>{p.meta.title}</h3>
      <p class="meta">{p.meta.published_at} — {p.meta.source_name}</p>
      <p>{p.meta.summary}</p>
      <span class="badge">{p.meta.risk_level}</span>
    </a>
  ))}
</Base>
